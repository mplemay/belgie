{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "types",
    "emitDeclarationOnly": true,
    "exactOptionalPropertyTypes": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts"
  ]
}
