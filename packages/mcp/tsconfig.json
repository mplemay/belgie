{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUnusedLocals": true,
    "paths": {
      "@belgie/mcp": [
        "./src/index.tsx"
      ],
      "@belgie/mcp/codegen": [
        "./src/codegen.ts"
      ],
      "@belgie/mcp/internal": [
        "./src/internal.ts"
      ],
      "@belgie/mcp/vite": [
        "./src/vite.ts"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "verbatimModuleSyntax": true
  },
  "exclude": [
    "coverage",
    "dist",
    "node_modules"
  ],
  "include": [
    "src",
    "tests/fixtures/**/*.ts",
    "tests/types.tsx",
    "*.config.ts"
  ]
}
