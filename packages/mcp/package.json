{
  "bin": {
    "belgie-mcp": "./dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "open": "^11.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "react-test-renderer": "19.2.6",
    "typescript": "~6.0.3",
    "vite": "8.1.3"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./types/index.d.ts"
    },
    "./codegen": {
      "import": "./dist/codegen.js",
      "types": "./types/codegen.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./types/vite.d.ts"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "main": "dist/index.js",
  "name": "@belgie/mcp",
  "peerDependencies": {
    "@modelcontextprotocol/ext-apps": ">=1.0.0",
    "vite": ">=8"
  },
  "private": false,
  "repository": {
    "directory": "packages/mcp",
    "type": "git",
    "url": "https://github.com/mplemay/belgie"
  },
  "scripts": {
    "build": "npm run clean && vite build && node ./node_modules/typescript/bin/tsc",
    "clean": "rm -rf dist types",
    "test": "npm run build && node --test test/*.test.mjs && node ./node_modules/typescript/bin/tsc --noEmit -p test/tsconfig.json"
  },
  "type": "module",
  "types": "types/index.d.ts",
  "version": "0.1.0"
}
