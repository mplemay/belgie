{
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "json-schema-to-typescript": "^15.0.4",
    "react-test-renderer": "19.2.6",
    "typescript": "~6.0.3",
    "vite": "8.1.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./types/index.d.ts"
    },
    "./generate": {
      "import": "./dist/generate.js",
      "types": "./types/generate.d.ts"
    },
    "./vite": {
      "import": "./dist/vite.js",
      "types": "./types/vite.d.ts"
    }
  },
  "files": [
    "dist",
    "types"
  ],
  "main": "dist/index.js",
  "name": "@belgie/mcp",
  "peerDependencies": {
    "@modelcontextprotocol/ext-apps": ">=1.0.0",
    "vite": ">=8"
  },
  "private": false,
  "repository": {
    "directory": "packages/mcp",
    "type": "git",
    "url": "https://github.com/mplemay/belgie"
  },
  "scripts": {
    "build": "vite build && vite build --config vite.generate.config.ts && node ./node_modules/typescript/bin/tsc && node ./node_modules/typescript/bin/tsc --project tsconfig.test.json",
    "clean": "rm -rf dist types",
    "test": "vitest run"
  },
  "type": "module",
  "types": "types/index.d.ts",
  "version": "0.1.0"
}
