    "vite": "^8.1.3"
  },
  "description": "Self-contained inline React widget rendering for Belgie run_code tools.",
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "publint": "^0.3.21",
    "tsdown": "^0.22.11",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/mplemay/belgie#inline-widget-rendering",
