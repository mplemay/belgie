BELGIE_BASE_URL=http://localhost:8000

BELGIE_STRIPE_EXAMPLE_SECRET_KEY=sk_test_replace_me
BELGIE_STRIPE_EXAMPLE_WEBHOOK_SECRET=whsec_replace_me
BELGIE_STRIPE_EXAMPLE_PRO_PRICE_ID=price_replace_me
BELGIE_STRIPE_EXAMPLE_PRO_ANNUAL_PRICE_ID=price_replace_me
